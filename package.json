{
  "name": "@steam0/sdk",
  "version": "0.1.0",
  "description": "Programmatic Steam top-up via cryptocurrency. Official client for steam0.shop.",
  "license": "MIT",
  "homepage": "https://github.com/fomeanator/steam0#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fomeanator/steam0.git"
  },
  "bugs": {
    "url": "https://github.com/fomeanator/steam0/issues"
  },
  "keywords": [
    "steam",
    "topup",
    "crypto",
    "usdt",
    "bitcoin",
    "ton",
    "agent",
    "ai",
    "api",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "steam0": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test --import tsx src/*.test.ts || true",
    "cli": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
